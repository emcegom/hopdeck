{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hopdeck",
  "version": "0.1.0",
  "identifier": "com.emcegom.hopdeck",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hopdeck",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["app"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/emcegom/hopdeck/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5MTM5MDg1RkU0QzA2RkEKUldUNkJreitoWkFUNmFIMTJUS0g1aXpWZzM0OUZzSEJhTklCZ1RzSTVPeFZtVTJSNmxEM2NJRXoK"
    }
  }
}
